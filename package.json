{
  "name": "smart-dependency-updater",
  "version": "1.0.0",
  "description": "AI-powered GitHub Action that analyzes failing CI on dependency-update PRs and auto-fixes breaking API changes, pushing the fix directly to the pull request.",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "all": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "github-action",
    "dependabot",
    "renovate",
    "dependencies",
    "openai",
    "llm",
    "ai",
    "ci",
    "automation",
    "remediation"
  ],
  "author": "mrdil07",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrdil07/Smart-Dependency-Updater.git"
  },
  "bugs": {
    "url": "https://github.com/mrdil07/Smart-Dependency-Updater/issues"
  },
  "homepage": "https://github.com/mrdil07/Smart-Dependency-Updater#readme",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "adm-zip": "^0.5.16",
    "openai": "^4.104.0"
  },
  "overrides": {
    "undici": "^6.26.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.9",
    "@vercel/ncc": "^0.38.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.6",
    "typescript": "^5.7.3"
  }
}
